[settings]
experimental = true
go_set_gobin = true

[tools]
# TODO: switch to upstream mdserve when my PRs are merged
# "github:jfernandez/mdserve" = "latest"
"cargo:https://github.com/quodlibetor/mdserve" = "branch:bwm-main"
"github:DeCarabas/fwd" = "latest"
"github:eza-community/eza" = "latest"
"github:golangci/golangci-lint" = "latest"
"github:ilyagr/diffedit3" = "latest"
"github:jesseduffield/lazygit" = "latest"
"github:michel-kraemer/zsh-patina" = "latest"
"github:quodlibetor/git-instafix" = "latest"
"github:quodlibetor/s3glob" = "latest"
"github:quodlibetor/vcs-status-daemon" = "latest"
"github:svenstaro/miniserve" = { version = "latest", matching = "miniserve", rename_exe = "miniserve", bin = "miniserve" }
"github:terrastruct/d2" = "latest"
"go:github.com/go-delve/delve/cmd/dlv" = "latest"
"go:golang.org/x/tools/gopls" = "latest"
"pipx:git-delete-merged-branches" = "latest"
"pipx:ruff" = "latest"
bat = "latest"
chezmoi = "latest"
difftastic = "latest"
dust = "latest"
fzf = "latest"
gh = "latest"
go = "latest"
jj = "latest"
jjui = "latest"
jq = "latest"
k9s = "latest"
node = "latest"
op = "latest"
python = "latest"
ripgrep = { version = "latest", exe = "rg" }
semgrep = "latest"
shellcheck = "latest"
starship = "latest"
tokei = "latest"
uv = "latest"
zoxide = "latest"

[tools.claude-code]
version = "latest"
minimum_release_age = "0m"

{{- if not (or (stat (joinPath .chezmoi.homeDir ".local/bin/vcs-status-daemon"))
               (stat (joinPath .chezmoi.homeDir ".cargo/bin/vcs-status-daemon"))) }}
{{/* if this exists I've installed from source */}}
"github:quodlibetor/vcs-status-daemon" = "latest"
{{- end -}}
{{ if (or (eq .chezmoi.os "linux")
          (not (eq .chezmoi.arch "amd64"))) -}}
{{/* packages which don't build for intel macs */}}
"github:chronologos/lightjj" = "latest"
{{- end }}
{{- if eq .chezmoi.os "linux" }}
btop = "latest"
delta = "latest"
fd = "latest"
{{- end }}
