#!/usr/bin/env zsh
## git auto branch
##
## Create a branch by normalizing the subject of a commit.
## Then, prompt if you'd like to push the branch to origin and potentially open
## a web browser to the create a PR page.
##
## Default rev is HEAD.

usage() {
  echo "Usage: $(basename $0) [REV]"
  echo
  echo "Create a branch by normalizing the subject of a commit."
  echo "Then, prompt if you'd like to push the change to origin and potentially open"
  echo "a web browser to the create a PR page."
  echo
  echo "Default rev is HEAD"
}

for arg in "$@"; do
  case "$arg" in
    -h|--help)
      usage
      exit 0
      ;;
  esac
done

local rev="${1:-HEAD}"

local default_branch=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's|refs/remotes/origin/||')
: "${default_branch:=main}"

# Check if the rev already has a branch pointing at it (excluding the default branch)
local existing_branch=$(git branch --points-at "$rev" --format='%(refname:short)' \
  | grep -v "^${default_branch}$" \
  | head -n1)

local branch
if [[ -n "$existing_branch" ]]; then
  branch="$existing_branch"
  echo "gitab: using existing branch '$branch'"
else
  local newname
  newname=$(git show -s --format=%s "$rev" \
    | sed -Ee 's/[^a-zA-Z0-9]+/_/g' \
    | sed -Ee 's/^-+|-+$//g' \
    | tr '[:upper:]' '[:lower:]' \
    ;
  )

  if [[ -z "$newname" ]]; then
    echo "gitab: could not derive a name from commit subject for rev: $rev" >&2
    return 1
  fi

  branch="bwm/$newname"

  if ! git rev-parse --quiet --verify "$branch" >/dev/null; then
    git branch "$branch" "$rev"
    echo "gitab: created $branch on $rev"
  fi
fi

local cmd=(git push -u origin "$branch")
local doit

local oldhist=""
local resethist=false
if [[ -n "${ZSH_AUTOSUGGEST_HISTORY_IGNORE:-}" ]]; then
  oldhist="${ZSH_AUTOSUGGEST_HISTORY_IGNORE}"
  resethist=true
fi

ZSH_AUTOSUGGEST_HISTORY_IGNORE=*

vared \
  -p "gitab: push new branch & create PR? [y/N] " \
  -r "${(j: :)cmd}" \
  doit

if $resethist ; then
  ZSH_AUTOSUGGEST_HISTORY_IGNORE="$oldhist"
else
  unset ZSH_AUTOSUGGEST_HISTORY_IGNORE
fi

if [[ "$doit" =~ ^[yY] ]]; then
  echo "> ${cmd[*]}"

  local outfile
  outfile=$(mktemp -t gitab.out.XXXXXXXXXX)

  "${cmd[@]}" >"$outfile" 2>&1

  cat "$outfile"
  local pr_url=$(grep -Eo 'https://github.com/.*pull/new[^ ]*' $outfile)
  rm "$outfile"
  if [[ -n "$pr_url" ]]; then
      python3 -m webbrowser "$pr_url"
  else
      echo "gitab: No PR URL found"
  fi
else
  # Put the push + PR command in clipboard (best-effort)
  local tocopy="git push -u origin $branch"
  print -r -- "$tocopy" | "$COPY_COMMAND"
  echo "gitab: branch/PR command is in your clipboard"
fi
