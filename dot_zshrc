# miniserve
ms() {
  # Figure out the port (miniserve defaults to 8080) so we can open the
  # browser without having to capture and parse miniserve's output.
  local port=8080 i
  for (( i = 1; i <= $#; i++ )); do
    case ${@[i]} in
      -p|--port) port=${@[i+1]} ;;
      -p=*|--port=*) port=${${@[i]}#*=} ;;
    esac
  done

  local opener
  if which open > /dev/null 2>&1; then
    opener=open
  elif which xdg-open > /dev/null 2>&1; then
    opener=xdg-open
  fi

  # Poll until the port accepts connections, then open the browser.
  # Backgrounded and disowned so it doesn't disturb miniserve on the terminal.
  if [[ -n $opener ]]; then
    (
      zmodload zsh/net/tcp
      local tries=0
      while ! ztcp localhost $port 2>/dev/null; do
        sleep 0.1
        (( ++tries > 100 )) && return   # give up after ~10s
      done
      ztcp -c 2>/dev/null
      $opener "http://localhost:$port"
    ) &!
  fi

  # Run miniserve in the foreground so it keeps the TTY: raw, colored output
  # and a working Ctrl-C.
  miniserve "$@"
}

# Vterm stuff, tells emacs which directory we're currently in
vterm_printf() {
    if [ -n "$TMUX" ]; then
        # Tell tmux to pass the escape sequences through
        # (Source: http://permalink.gmane.org/gmane.comp.terminal-emulators.tmux.user/1324)
        printf "\ePtmux;\e\e]%s\007\e\\" "$1"
    elif [ "${TERM%%-*}" = "screen" ]; then
        # GNU screen (screen, screen-256color, screen-256color-bce)
        printf "\eP\e]%s\007\e\\" "$1"
    else
        printf "\e]%s\e\\" "$1"
    fi
}

