# Extra commands

# Cache the output of `<tool> init`-style commands keyed by the tool binary's
# mtime. Saves several hundred ms of subprocess startup per shell.
__bwm_cached_eval() {
  local name="$1"; shift
  local bin_path="$1"; shift
  local cache_dir="${XDG_CACHE_HOME:-$HOME/.cache}/zsh-init"
  local cache_file="$cache_dir/$name.zsh"
  [[ -d $cache_dir ]] || mkdir -p "$cache_dir"
  if [[ ! -s $cache_file || $bin_path -nt $cache_file ]]; then
    "$@" > "$cache_file"
    zcompile -R -- "$cache_file" 2>/dev/null
  fi
  source "$cache_file"
}

if (( $+commands[mise] )); then
  __bwm_cached_eval mise-activate "$commands[mise]" mise activate zsh

  # mise's precmd/chpwd hooks spawn `mise hook-env` (~68ms) on every prompt and
  # cd. Wrap them so we only call mise when the set of config files (or their
  # mtimes) that would influence its output has actually changed.
  zmodload -F zsh/stat b:zstat
  typeset -g __bwm_mise_last_sig=""

  __bwm_mise_sig() {
    local dir="$PWD" name
    local -a t
    REPLY=""
    if zstat -A t +mtime -- "$HOME/.config/mise/config.toml" 2>/dev/null; then
      REPLY+="g:${t[1]};"
    fi
    while [[ $dir != / && -n $dir ]]; do
      for name in mise.toml .mise.toml mise.local.toml .mise.local.toml .tool-versions; do
        if zstat -A t +mtime -- "$dir/$name" 2>/dev/null; then
          REPLY+="$dir/$name:${t[1]};"
        fi
      done
      dir=${dir:h}
    done
  }

  _mise_hook_precmd() {
    if [[ "${__MISE_ZSH_CHPWD_RAN:-0}" == "1" ]]; then
      export __MISE_ZSH_CHPWD_RAN=0
      return
    fi
    __bwm_mise_sig
    [[ $REPLY == "$__bwm_mise_last_sig" ]] && return
    __bwm_mise_last_sig=$REPLY
    eval "$("$commands[mise]" hook-env -s zsh --reason precmd)"
  }

  _mise_hook_chpwd() {
    export __MISE_ZSH_CHPWD_RAN=1
    __bwm_mise_sig
    [[ $REPLY == "$__bwm_mise_last_sig" ]] && return
    __bwm_mise_last_sig=$REPLY
    eval "$("$commands[mise]" hook-env -s zsh --reason chpwd)"
  }

  # mise activate's tail already ran _mise_hook synchronously, so seed the
  # cached signature here to avoid one redundant call on the first prompt.
  __bwm_mise_sig
  __bwm_mise_last_sig=$REPLY
fi
